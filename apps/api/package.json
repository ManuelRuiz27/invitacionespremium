{
  "name": "@invitaciones/api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "prisma generate && nest start --watch",
    "build": "prisma generate && nest build",
    "start": "node dist/main.js",
    "lint": "eslint src test scripts",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "test": "prisma generate && vitest run --config vitest.config.ts",
    "test:integration": "prisma generate && vitest run --config vitest.integration.config.ts",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "db:migrate:deploy": "prisma migrate deploy",
    "openapi:generate": "prisma generate && tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.6",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "dotenv": "^17.2.3",
    "prisma": "^7.9.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "vitest": "^4.1.10"
  }
}
