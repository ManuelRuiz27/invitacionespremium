generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AuditActorType {
  USER
  STAFF_TOKEN
  PUBLIC_TOKEN
  SYSTEM

  @@map("audit_actor_type")
}

enum UserRole {
  PLATFORM_ADMIN
  INDEPENDENT_PLANNER
  ORGANIZATION_ADMIN
  ORGANIZATION_PLANNER

  @@map("user_role")
}

model AuditLog {
  id               String         @id @default(uuid()) @db.Uuid
  actorType        AuditActorType @map("actor_type")
  actorId          String?        @map("actor_id") @db.Uuid
  actorFingerprint String?        @map("actor_fingerprint") @db.Char(64)
  clientId         String?        @map("client_id") @db.Uuid
  eventId          String?        @map("event_id") @db.Uuid
  resourceType     String         @map("resource_type") @db.VarChar(100)
  resourceId       String?        @map("resource_id") @db.Uuid
  action           String         @db.VarChar(120)
  beforeData       Json?          @map("before_data")
  afterData        Json?          @map("after_data")
  metadata         Json?
  operationId      String?        @map("operation_id") @db.Uuid
  occurredAt       DateTime       @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([clientId, occurredAt])
  @@index([eventId, occurredAt])
  @@index([resourceType, resourceId, occurredAt])
  @@index([operationId])
  @@map("audit_log")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique @db.VarChar(320)
  passwordHash String        @map("password_hash") @db.Text
  role         UserRole
  clientId     String?       @map("client_id") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)
  sessions     AuthSession[]

  @@index([clientId])
  @@index([role, deletedAt])
  @@map("app_user")
}

model AuthSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.Char(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
  @@map("auth_session")
}
