NODE_ENV=development
API_PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invitacionespremium
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
LOG_LEVEL=debug
SWAGGER_ENABLED=true
AUTH_SESSION_TTL_SECONDS=28800
AUTH_COOKIE_NAME=ip_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_PATH=/api/v1
LOCAL_ADMIN_EMAIL=admin@example.com
LOCAL_ADMIN_PASSWORD=change-me-at-least-12-chars
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_SOCKET_URL=http://localhost:3000
