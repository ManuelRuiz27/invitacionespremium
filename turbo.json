{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "API_PORT",
    "DATABASE_URL",
    "DATABASE_POOL_MAX",
    "DATABASE_CONNECTION_TIMEOUT_MS",
    "DATABASE_IDLE_TIMEOUT_MS",
    "CORS_ORIGINS",
    "LOG_LEVEL",
    "SWAGGER_ENABLED"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false,
      "outputs": ["src/generated/prisma/**"]
    }
  }
}
